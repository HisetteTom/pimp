{
  "name": "pimp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node server.js",
    "build": "next build && node scripts/copy-standalone-server.js",
    "start": "node .next/standalone/server.js",
    "lint": "eslint",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun scripts/seed-data.ts",
    "db:seed-lookups": "bun src/db/seed-lookups.ts",
    "db:dbml": "bun scripts/generate-dbml.ts",
    "setup": "bun scripts/setup.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "doctor": "bun react-doctor --full",
    "doctor:json": "bun react-doctor --full --json --verbose",
    "lint-staged": "lint-staged --allow-empty",
    "prepare": "simple-git-hooks",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1058.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@hookform/resolvers": "^5.4.0",
    "@remixicon/react": "^4.9.0",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.6.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hash-wasm": "^4.12.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-intl": "^4.13.0",
    "next-themes": "0.4.6",
    "pg": "^8.21.0",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.77.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.10.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,css,json,yml}": [
      "prettier --write"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "bun lint-staged"
  },
  "devDependencies": {
    "@drizzle-team/studio": "^1.0.3",
    "drizzle-kit": "^0.31.10",
    "@faker-js/faker": "^10.4.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-plugin-react-compiler": "1.0.0",
    "bun-types": "^1.3.14",
    "drizzle-dbml-generator": "^0.10.0",
    "eslint": "^10.4.1",
    "eslint-config-next": "16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.9.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react-doctor": "^0.2.16",
    "react-scan": "^0.5.7",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
